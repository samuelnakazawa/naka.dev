#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

# Validate commit message format
# Examples of valid formats:
# feat: add new feature
# fix: correct bug
# docs: update documentation
# style: format code
# refactor: restructure code
# test: add tests
# chore: update dependencies

commit_msg=$(cat "$1")
pattern="^(feat|fix|docs|style|refactor|test|chore|perf|ci|build|revert)(\(.+\))?: .{1,}"

if ! echo "$commit_msg" | grep -iqE "$pattern"; then
    echo "❌ Invalid commit message format!"
    echo ""
    echo "Commit message must follow the pattern:"
    echo "  type(scope?): subject"
    echo ""
    echo "Types: feat, fix, docs, style, refactor, test, chore, perf, ci, build, revert"
    echo ""
    echo "Examples:"
    echo "  feat: add new feature"
    echo "  fix: correct login bug"
    echo "  docs(readme): update installation steps"
    echo ""
    exit 1
fi
